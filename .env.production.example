# Production env template — copy to .env on the deployment VM and fill
# with real secrets. NEVER commit the real .env (gitignored).
#
# Local dev uses .env.example (separate file with localhost defaults).
#
# External services stay the same when moving Azure → Hetzner → Oracle
# → anywhere. The VM only hosts the 3 containers; everything else is
# managed by external providers.

# ── Postgres (Neon, EU central) ─────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# ── Redis (Upstash, EU) ─────────────────────────────────────────────
REDIS_URL=rediss://default:PASSWORD@HOST:6379

# ── Cloudflare R2 (S3-compatible blob storage) ──────────────────────
R2_ACCOUNT_ID=
R2_BUCKET=quilpen
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ── Anthropic Claude (Haiku for metadata, Sonnet for writing) ───────
ANTHROPIC_API_KEY=

# ── Google AI (optional gemini fallback) ────────────────────────────
GOOGLE_AI_API_KEY=

# ── NextAuth ────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://quilpen.com

# ── Google OAuth ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Modal Surya OCR (heavy scan routing) ────────────────────────────
SURYA_OCR_URL=
OCR_SERVICE_SECRET=

# ── Admin ───────────────────────────────────────────────────────────
ADMIN_SESSION_SECRET=
ADMIN_BULK_IMPORT_TOKEN=

# ── Email (Resend) ──────────────────────────────────────────────────
EMAIL_FROM=Quilpen <noreply@quilpen.com>
RESEND_API_KEY=

# ── Paddle (subscriptions) ──────────────────────────────────────────
PADDLE_ENVIRONMENT=production
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_ENVIRONMENT=production
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
PADDLE_PRICE_STARTER_MONTH=
PADDLE_PRICE_STARTER_YEAR=
PADDLE_PRICE_PRO_MONTH=
PADDLE_PRICE_PRO_YEAR=
NEXT_PUBLIC_PADDLE_PRICE_STARTER_MONTH=
NEXT_PUBLIC_PADDLE_PRICE_STARTER_YEAR=
NEXT_PUBLIC_PADDLE_PRICE_PRO_MONTH=
NEXT_PUBLIC_PADDLE_PRICE_PRO_YEAR=
