generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ==================== AUTH ====================

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                 String              @id @default(cuid())
  name               String?
  email              String?             @unique
  emailVerified      DateTime?
  image              String?
  accounts           Account[]
  sessions           Session[]
  projects           Project[]
  series             Series[]
  libraryEntries     LibraryEntry[]
  libraryChatMessages LibraryChatMessage[]
  libraryTags        LibraryTag[]
  libraryCollections LibraryCollection[]
  libraryNotes       LibraryNote[]
  libraryHighlights  LibraryHighlight[]
  zoteroConnection   ZoteroConnection?
  creditBalance      Int                 @default(1500)
  creditTransactions CreditTransaction[]
  styleProfiles      UserStyleProfile[]
  styleSamples       StyleSample[]
  backgroundJobs     BackgroundJob[]

  // Subscription / billing (Paddle). Tier maps to monthly credit allowance
  // in lib/billing/tiers.ts. creditsResetAt is the wall-clock moment we
  // last refilled the monthly bucket — Free is lazy-reset on month flip,
  // paid tiers are reset by the Paddle transaction.completed webhook.
  paddleCustomerId     String?
  paddleSubscriptionId String?   @unique
  subscriptionTier     String    @default("free")
  subscriptionStatus   String    @default("active")
  subscriptionPriceId  String?
  currentPeriodEnd     DateTime?
  creditsResetAt       DateTime?

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==================== ADMIN ====================

model AdminUser {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?
}

// ==================== USER STYLE PROFILES ====================

model UserStyleProfile {
  id        String   @id @default(cuid())
  userId    String
  name      String
  profile   Json?
  method    String   @default("chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatMessages StyleChatMessage[]
  samples      StyleSample[]
  projects     Project[]          @relation("ProjectLinkedStyle")

  @@index([userId])
}

// User-supplied writing samples that fed the Writing Twin analysis.
// Persisted so the detail panel can show what the profile was built
// on; the "Örnek metinler" list pulls from this table.
model StyleSample {
  id        String   @id @default(cuid())
  userId    String
  profileId String
  /** Free-form label — usually the original filename for uploads or a
   *  synthesised "Örnek N" tag for pasted text. */
  filename  String
  content   String   @db.Text
  wordCount Int      @default(0)
  /** How the sample entered the system. Helps the UI display origin
   *  badges and lets the analyze pipeline skip re-ingesting later. */
  origin    String   @default("paste") // paste | upload | chat
  createdAt DateTime @default(now())

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile UserStyleProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, createdAt])
  @@index([userId])
}

model StyleChatMessage {
  id             String   @id @default(cuid())
  styleProfileId String
  sessionId      String
  role           String
  content        String   @db.Text
  createdAt      DateTime @default(now())

  styleProfile UserStyleProfile @relation(fields: [styleProfileId], references: [id], onDelete: Cascade)

  @@index([styleProfileId, sessionId, createdAt])
}

// ==================== PROJECT ====================

enum ProjectStatus {
  onboarding
  roadmap
  sources
  writing
  completed
}

enum ProjectType {
  ACADEMIC
  BOOK
  STORY
  CREATIVE
}

enum CitationFormat {
  ISNAD
  APA
  CHICAGO
  MLA
  HARVARD
  VANCOUVER
  IEEE
  AMA
  TURABIAN
}

model Project {
  id                String         @id @default(cuid())
  userId            String
  title             String
  description       String?        @db.Text
  topic             String?        @db.Text
  purpose           String?        @db.Text
  audience          String?
  language          String         @default("en")
  projectType       ProjectType    @default(ACADEMIC)
  citationFormat    CitationFormat @default(ISNAD)
  styleProfile      Json?
  styleProfileId    String?
  writingGuidelines Json?
  bookDesign        Json?
  status            ProjectStatus  @default(onboarding)

  // Optional series link — for multi-volume works (külliyat, fantasy
  // series, encyclopedia). Each volume stays a standalone Project
  // with its own roadmap/chapters; Series is just a grouping.
  seriesId    String?
  seriesOrder Int?

  // Academic metadata — populates title page, abstract, TOC, running heads
  // when the project is exported in an academic citation format.
  author          String?
  institution     String?
  department      String?
  advisor         String?
  abstractTr      String?  @db.Text
  abstractEn      String?  @db.Text
  keywordsTr      String[]
  keywordsEn      String[]
  acknowledgments String?  @db.Text
  dedication      String?  @db.Text
  // When true the title page and running heads omit author/institution/
  // department/advisor — used for double-blind journal submissions.
  blindReview     Boolean  @default(false)

  user               User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedStyleProfile UserStyleProfile?         @relation("ProjectLinkedStyle", fields: [styleProfileId], references: [id], onDelete: SetNull)
  series             Series?                   @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  academicMeta       ProjectAcademicMeta?
  chapters           Chapter[]
  sources            Source[]
  bibliography       Bibliography[]
  outputs            Output[]
  chatMessages       RoadmapChatMessage[]
  characters         Character[]
  projectImages      ProjectImage[]
  illustrationChats  IllustrationChatMessage[]
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@index([seriesId, seriesOrder])
}

model Series {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]

  @@unique([userId, name])
  @@index([userId])
}

// ==================== ACADEMIC METADATA ====================

// Format-discriminated academic metadata. `meta` is a JSON blob whose
// shape is governed by src/lib/academic-meta/schemas.ts — one Zod
// variant per CitationFormat. `format` and `schemaVersion` are duplicated
// out of the JSON so reads can branch without parsing.
model ProjectAcademicMeta {
  projectId     String         @id
  format        CitationFormat
  schemaVersion Int            @default(1)
  meta          Json
  updatedAt     DateTime       @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([format])
}

// ==================== ROADMAP CHAT ====================

model RoadmapChatMessage {
  id              String   @id @default(cuid())
  projectId       String
  sessionId       String
  role            String // "user" | "assistant"
  content         String   @db.Text
  commands        Json?
  commandsApplied Boolean  @default(false)
  createdAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sessionId, createdAt])
}

// ==================== BOOK STRUCTURE ====================

model Chapter {
  id             String  @id @default(cuid())
  projectId      String
  number         Int
  title          String
  purpose        String? @db.Text
  estimatedPages Int?
  sortOrder      Int

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sections      Section[]
  projectImages ProjectImage[]

  @@unique([projectId, number])
}

model Section {
  id          String   @id @default(cuid())
  chapterId   String
  sectionId   String // "1.1" format
  title       String
  keyConcepts String[]
  sortOrder   Int

  chapter     Chapter      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  subsections Subsection[]

  @@unique([chapterId, sectionId])
}

enum SubsectionStatus {
  pending
  in_progress
  paused
  draft
  review
  completed
}

model Subsection {
  id              String           @id @default(cuid())
  sectionId       String
  subsectionId    String // "1.1.1" format
  title           String
  description     String?          @db.Text
  whatToWrite     String?          @db.Text
  keyPoints       String[]
  writingStrategy String?          @db.Text
  estimatedPages  Int?
  status          SubsectionStatus @default(pending)
  content         String?          @db.Text
  wordCount       Int              @default(0)
  sortOrder       Int

  section         Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sourceMappings  SourceMapping[]
  writingSessions WritingSession[]
  outputs         Output[]
  projectImages   ProjectImage[]

  @@unique([sectionId, subsectionId])
}

// ==================== SOURCES ====================

model Source {
  id         String  @id @default(cuid())
  projectId  String
  filename   String
  filePath   String
  fileType   String
  totalPages Int?
  processed  Boolean @default(false)

  project      Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bibliography Bibliography[]
  attachments  BibliographyAttachment[]
  chunks       SourceChunk[]
  createdAt    DateTime                 @default(now())
}

enum EntryType {
  kitap
  makale
  nesir
  ceviri
  tez
  ansiklopedi
  web
}

model Bibliography {
  id            String    @id @default(cuid())
  projectId     String
  sourceId      String?
  entryType     EntryType @default(kitap)
  authorSurname String
  authorName    String?
  /**
   * Co-authors of the work, in order. Each entry: { surname, name? }.
   * `authorSurname` + `authorName` is always the first author; this
   * array holds the 2nd … Nth authors so format-specific "et al."
   * truncation rules (APA 7 → 21+, Vancouver/AMA/IEEE → 6+, MLA → 3+,
   * Chicago notes → 4+, Harvard → 3+) can render the whole list.
   */
  coAuthors     Json?
  title         String
  shortTitle    String?
  editor        String?
  translator    String?
  publisher     String?
  publishPlace  String?
  year          String?
  volume        String?
  edition       String?
  journalName   String?
  journalVolume String?
  journalIssue  String?
  pageRange     String?
  doi           String?
  url           String?
  accessDate    String?
  metadata      Json?

  libraryEntryId String?
  project        Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source         Source?                  @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  libraryEntry   LibraryEntry?            @relation(fields: [libraryEntryId], references: [id], onDelete: SetNull)
  sourceMappings SourceMapping[]
  chunks         SourceChunk[]
  attachments    BibliographyAttachment[]
  createdAt      DateTime                 @default(now())
}

model BibliographyAttachment {
  id             String   @id @default(cuid())
  bibliographyId String
  sourceId       String
  createdAt      DateTime @default(now())

  bibliography Bibliography @relation(fields: [bibliographyId], references: [id], onDelete: Cascade)
  source       Source       @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([bibliographyId, sourceId])
}

model SourceMapping {
  id              String  @id @default(cuid())
  subsectionId    String
  bibliographyId  String
  relevance       String? @db.Text
  priority        String  @default("supporting") // primary | supporting
  howToUse        String? @db.Text
  whereToFind     String?
  extractionGuide String? @db.Text
  sourceType      String  @default("modern") // "classical" | "modern"

  subsection   Subsection   @relation(fields: [subsectionId], references: [id], onDelete: Cascade)
  bibliography Bibliography @relation(fields: [bibliographyId], references: [id], onDelete: Cascade)

  @@unique([subsectionId, bibliographyId])
}

model SourceChunk {
  id             String                      @id @default(cuid())
  sourceId       String
  bibliographyId String?
  pageNumber     Int?
  chunkIndex     Int
  content        String                      @db.Text
  embedding      Unsupported("vector(768)")?
  metadata       Json?

  source       Source        @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  bibliography Bibliography? @relation(fields: [bibliographyId], references: [id], onDelete: SetNull)
}

// ==================== WRITING ====================

model WritingSession {
  id               String  @id @default(cuid())
  subsectionId     String
  context          Json?
  sourcesUsed      Json?
  promptSent       String? @db.Text
  responseReceived String? @db.Text
  status           String  @default("pending")

  subsection Subsection @relation(fields: [subsectionId], references: [id], onDelete: Cascade)
  createdAt  DateTime   @default(now())
}

// ==================== OUTPUTS ====================

model Output {
  id           String  @id @default(cuid())
  projectId    String
  subsectionId String?
  fileType     String  @default("docx")
  filePath     String
  scope        String  @default("subsection") // subsection | chapter | full
  driveFileId  String?
  driveWebLink String?

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subsection Subsection? @relation(fields: [subsectionId], references: [id], onDelete: SetNull)
  createdAt  DateTime    @default(now())
}

// ==================== USER LIBRARY ====================

model LibraryEntry {
  id            String    @id @default(cuid())
  userId        String
  entryType     EntryType @default(kitap)
  authorSurname String
  authorName    String?
  /**
   * Co-authors of the work; mirror of `Bibliography.coAuthors`.
   */
  coAuthors     Json?
  title         String
  shortTitle    String?
  editor        String?
  translator    String?
  publisher     String?
  publishPlace  String?
  year          String?
  volume        String?
  edition       String?
  journalName   String?
  journalVolume String?
  journalIssue  String?
  pageRange     String?
  doi           String?
  url           String?
  accessDate    String?
  metadata      Json?
  importSource  String? // "manual" | "bibtex" | "zotero" | "literature-search" | "pdf-upload"
  bibtexKey     String?
  zoteroKey     String?
  filePath      String? // Local path to downloaded PDF/file
  fileType      String? // "pdf" | "doc" | etc.

  // Literature-search enrichment
  abstract       String?  @db.Text
  keywords       String[] @default([])
  citationCount  Int?
  relevanceScore Float? // Haiku-scored against the user's query
  openAccessUrl  String? // Direct PDF URL when open access
  pdfStatus      String   @default("none") // "none" | "pending" | "downloading" | "extracting" | "embedding" | "ready" | "failed"
  pdfError       String?

  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  bibliographies Bibliography[]
  tags           LibraryEntryTag[]
  chunks         LibraryChunk[]
  volumes        LibraryEntryVolume[]
  collections    LibraryEntryCollection[]
  notes          LibraryNote[]
  highlights     LibraryHighlight[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, authorSurname, title])
  @@index([userId])
  @@index([userId, pdfStatus])
}

// A multi-volume work (Tabari Tafsir, hadith külliyatı, ansiklopedi)
// is a single bibliographic entry with N physical volumes. Each volume
// gets its own PDF and chunks; citations target a (entry, volume, page)
// tuple. Single-volume entries skip this table entirely and use
// LibraryEntry.filePath / chunks directly — fully backward-compatible.
model LibraryEntryVolume {
  id             String   @id @default(cuid())
  libraryEntryId String
  volumeNumber   Int // 1, 2, 3, ... — what the user types after "c."
  label          String? // optional title, e.g. "Hicret Öncesi"
  filePath       String? // PDF on the durable volume mount
  fileType       String? @default("pdf")
  pdfStatus      String  @default("none")
  pdfError       String?
  totalPages     Int?

  libraryEntry LibraryEntry   @relation(fields: [libraryEntryId], references: [id], onDelete: Cascade)
  chunks       LibraryChunk[]
  notes        LibraryNote[]
  highlights   LibraryHighlight[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([libraryEntryId, volumeNumber])
  @@index([libraryEntryId])
}

model LibraryChunk {
  id             String                      @id @default(cuid())
  libraryEntryId String
  // When the entry is a multi-volume work, every chunk is tagged with
  // the volume it came from. NULL means "the entry's primary PDF" —
  // single-volume legacy entries leave this empty.
  volumeId       String?
  // pageNumber is the 1-indexed PDF page (what pdfjs/PyMuPDF call
  // "page N of N"). pdfPageLabel is the *printed* page number from
  // the book itself ("49" when the PDF page is 64 because of front
  // matter). Citation renderers should prefer pdfPageLabel; viewer
  // input still navigates by pageNumber.
  pageNumber     Int?
  pdfPageLabel   String?
  // Closest preceding heading on the page (e.g. "Chapter 3:
  // Concepts of Pollution", "BÖLÜM 2"). Tracked during extraction
  // by the heading-detection pass and copied onto every chunk that
  // sits under it. Used both for richer retrieval prompts and for
  // letting the UI show a section breadcrumb on each citation chip.
  sectionTitle   String?
  // Short LLM-generated context prepended to `content` before
  // embedding — e.g. "From Mary Douglas, Saflık ve Tehlike, ch. 3
  // on pollution rituals: …". Anthropic's "Contextual Retrieval"
  // (2024) paper shows this lifts retrieval precision ~35% by
  // anchoring every chunk to its source's identity and topic
  // instead of leaving embedding to guess from bare prose.
  // `content` stays as the raw passage so display/highlight code
  // doesn't change. NULL on chunks that pre-date this pass.
  contextualPrefix String?
  chunkIndex     Int
  content        String                      @db.Text
  embedding      Unsupported("vector(768)")?
  metadata       Json?

  libraryEntry LibraryEntry         @relation(fields: [libraryEntryId], references: [id], onDelete: Cascade)
  volume       LibraryEntryVolume?  @relation(fields: [volumeId], references: [id], onDelete: Cascade)

  @@index([libraryEntryId])
  @@index([volumeId])
}

// User-defined hierarchical folder over library entries. Unlike tags
// which are flat, collections nest (parent → child) and a single entry
// can sit in many folders. Used for Zotero-style organisation:
// "Tez/Kelam/Mâtürîdî", "Tez/Tasavvuf", "Modern okumalar" etc.
//
// Sort order is user-controlled within each parent — drag to reorder
// in the sidebar. Deleting a folder cascades to its children but
// LEAVES the entries themselves alone (junction rows are removed via
// LibraryEntryCollection's cascade on the collectionId side).
model LibraryCollection {
  id        String   @id @default(cuid())
  userId    String
  parentId  String?
  name      String
  color     String?
  sortOrder Int      @default(0)

  user     User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   LibraryCollection?       @relation("CollectionTree", fields: [parentId], references: [id], onDelete: Cascade)
  children LibraryCollection[]      @relation("CollectionTree")
  entries  LibraryEntryCollection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Uniqueness lives within a parent, including the null parent at the
  // tree root. "Kelam" at root + "Kelam" under "Tez" coexist; two
  // "Kelam"s under the same parent do not.
  @@unique([userId, parentId, name])
  @@index([userId])
  @@index([parentId])
}

// Many-to-many join: an entry can live in any number of folders.
// addedAt lets the UI show "Added to 'Kelam' 3 days ago" if we ever
// want it.
model LibraryEntryCollection {
  libraryEntryId String
  collectionId   String
  addedAt        DateTime @default(now())

  libraryEntry LibraryEntry      @relation(fields: [libraryEntryId], references: [id], onDelete: Cascade)
  collection   LibraryCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([libraryEntryId, collectionId])
  @@index([collectionId])
}

// User-authored notes attached to a library entry. Stored as Tiptap
// JSON in `content` (rich text + formatting + headings + lists + block
// quotes + highlights) plus a flattened plaintext `contentText` for
// pgvector embedding + full-text search.
//
// volumeId is optional: for multi-volume works (Tabari Tafsir, etc.)
// notes can be anchored to a specific cilt; the parent-level note has
// volumeId = NULL.
//
// pageNumber is optional: notes captured from a PDF highlight remember
// the page they came from so the UI can jump back. Free-form notes
// don't set it.
//
// pinnedFromChatSessionId is set when the note was created by clicking
// "📌 Nota Kaydet" on a library chat message — lets the UI link back
// to the original conversation.
//
// Same vector(768) dimension as LibraryChunk so the chat retrieval
// query can UNION the two embedding tables in one ORDER BY ... <-> $1.
model LibraryNote {
  id                      String   @id @default(cuid())
  libraryEntryId          String
  volumeId                String?
  userId                  String
  title                   String?
  content                 Json
  contentText             String   @db.Text
  embedding               Unsupported("vector(768)")?
  pageNumber              Int?
  // Printed page label captured from the PDF (the "49" stamped on
  // the page even when pageNumber is 64). The viewer pulls these
  // from pdfjs.getPageLabels() and sends them on highlight save;
  // citation surfaces prefer this over pageNumber.
  pdfPageLabel            String?
  pinnedFromChatSessionId String?

  libraryEntry LibraryEntry        @relation(fields: [libraryEntryId], references: [id], onDelete: Cascade)
  volume       LibraryEntryVolume? @relation(fields: [volumeId], references: [id], onDelete: SetNull)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  highlights   LibraryHighlight[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([libraryEntryId])
  @@index([userId])
  @@index([volumeId])
}

// PDF highlights: a user selects text on a page, we save the selected
// quote + the bounding rectangles (normalised 0-1 to the page size so
// they survive zoom and viewport changes). Each highlight can optionally
// be paired with a LibraryNote — the "Highlight + Not" floating action
// creates both at once and links them.
model LibraryHighlight {
  id             String   @id @default(cuid())
  libraryEntryId String
  volumeId       String?
  noteId         String?
  userId         String
  pageNumber     Int
  // Mirrors LibraryNote.pdfPageLabel; saved alongside pageNumber when
  // the viewer creates the highlight so citations of the highlight
  // (or its linked note) display the printed book page.
  pdfPageLabel   String?
  text           String   @db.Text
  rangeRects     Json     // [{ x, y, w, h }] in 0-1 page-relative units
  color          String   @default("#FFEB3B")
  createdAt      DateTime @default(now())

  libraryEntry LibraryEntry        @relation(fields: [libraryEntryId], references: [id], onDelete: Cascade)
  volume       LibraryEntryVolume? @relation(fields: [volumeId], references: [id], onDelete: SetNull)
  note         LibraryNote?        @relation(fields: [noteId], references: [id], onDelete: SetNull)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([libraryEntryId, pageNumber])
  @@index([userId])
  @@index([noteId])
}

// "Chat with your PDFs" feature — turns the user's library into a
// queryable corpus. Messages persist per session so the user can come
// back to a thread later. Sources is a denormalised JSON snapshot of
// the chunks the assistant cited — chunk rows themselves can be
// re-embedded or deleted, but the answer's citations stay readable.
model LibraryChatMessage {
  id        String   @id @default(cuid())
  userId    String
  sessionId String
  role      String // "user" | "assistant"
  content   String   @db.Text
  scope     String? // "all" | "picked" | "single" — only set on user rows
  entryIds  String[] // selected library entries when scope != "all"
  sources   Json? // citations on assistant rows: [{ entryId, title, page }]
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sessionId, createdAt])
}

model LiteratureSearchCache {
  id        String   @id @default(cuid())
  userId    String
  queryHash String // sha256(normalized query + filters)
  query     String
  filters   Json?
  results   Json // AcademicSearchResult[] after ranking
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@unique([userId, queryHash])
  @@index([expiresAt])
}

model LibraryTag {
  id     String @id @default(cuid())
  userId String
  name   String

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries LibraryEntryTag[]

  @@unique([userId, name])
}

model LibraryEntryTag {
  id             String @id @default(cuid())
  libraryEntryId String
  tagId          String

  entry LibraryEntry @relation(fields: [libraryEntryId], references: [id], onDelete: Cascade)
  tag   LibraryTag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([libraryEntryId, tagId])
}

// ==================== ZOTERO ====================

model ZoteroConnection {
  id              String    @id @default(cuid())
  userId          String    @unique
  apiKey          String
  zoteroUserId    String
  lastSyncAt      DateTime?
  syncCollections String[]

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== CREDITS ====================

enum CreditTransactionType {
  initial_grant
  admin_grant
  purchase
  ai_operation
  refund
  subscription_renewal
}

model CreditTransaction {
  id                  String                @id @default(cuid())
  userId              String
  amount              Int
  balance             Int
  type                CreditTransactionType
  operation           String?
  inputTokens         Int?
  outputTokens        Int?
  cacheReadTokens     Int?
  cacheCreationTokens Int?
  creditsUsed         Int?
  model               String?
  metadata            Json?
  createdAt           DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ==================== ILLUSTRATIONS ====================

model Character {
  id            String   @id @default(cuid())
  projectId     String
  name          String
  description   String?  @db.Text
  visualTraits  String?  @db.Text
  referenceData Bytes?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectImage {
  id           String   @id @default(cuid())
  projectId    String
  chapterId    String?
  subsectionId String?
  imageData    Bytes
  prompt       String   @db.Text
  style        String?
  aspectRatio  String   @default("4:3")
  layout       String   @default("float_right")
  position     String   @default("after")
  widthPercent Int      @default(50)
  posX         Float    @default(0)
  posY         Float    @default(0)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter    Chapter?    @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  subsection Subsection? @relation(fields: [subsectionId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([chapterId])
}

model IllustrationChatMessage {
  id        String   @id @default(cuid())
  projectId String
  sessionId String
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sessionId, createdAt])
}

// ==================== BACKGROUND JOBS ====================
// Tracks long-running operations (roadmap generation, subsection writing,
// literature search, zotero sync, etc.) so the UI can show progress in
// a notification bell even after the user navigates away.

model BackgroundJob {
  id           String    @id @default(cuid())
  userId       String
  type         String // 'roadmap' | 'subsection' | 'batch_writing' | 'literature_search' | 'zotero_sync' | 'pdf_pipeline'
  status       String    @default("running") // 'running' | 'done' | 'failed'
  title        String
  projectId    String? // optional — for deep-linking
  subsectionId String? // optional — for deep-linking
  resultUrl    String? // where to send the user on click
  progress     Int? // 0..100 when known
  message      String? // latest status message
  error        String?   @db.Text
  acknowledged Boolean   @default(false)
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, startedAt])
}
