DATABASE_URL="postgresql://writer:writer_dev_2024@localhost:5432/writer_agent?schema=public"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secret-here"

# Admin panel session (min 32 chars, e.g. `openssl rand -hex 32`)
ADMIN_SESSION_SECRET="generate-a-32-char-secret-here"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Resend (email verification codes)
# Sign up at resend.com, free tier = 3000 emails/mo. For prod, verify your own domain.
RESEND_API_KEY="re_your_api_key"
EMAIL_FROM="Quilpen <hello@yourdomain.com>"

# Claude API
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Gemini Embedding
GOOGLE_AI_API_KEY="your-google-ai-api-key"

# Python Service
PYTHON_SERVICE_URL="http://localhost:8000"

# ─── Paddle (subscriptions) ────────────────────────────────────────────────
# Required to power /pricing, /account, and the Paddle webhook. Use sandbox
# values during development, switch to production once verified.
# See docs/PADDLE_SETUP.md for the full Paddle dashboard walkthrough.

PADDLE_ENVIRONMENT="sandbox"
PADDLE_API_KEY="pdl_apikey_xxx"
PADDLE_WEBHOOK_SECRET="pdl_ntfset_xxx"

# Public keys are exposed to the browser — required for the Checkout overlay.
NEXT_PUBLIC_PADDLE_ENVIRONMENT="sandbox"
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN="live_xxx_or_test_xxx"

# Paddle Price IDs — one per tier × interval. Get them from the Paddle
# dashboard after creating the Quilpen Starter and Quilpen Pro products.
PADDLE_PRICE_STARTER_MONTH="pri_xxx"
PADDLE_PRICE_STARTER_YEAR="pri_xxx"
PADDLE_PRICE_PRO_MONTH="pri_xxx"
PADDLE_PRICE_PRO_YEAR="pri_xxx"

# Same Price IDs, exposed to the browser so Paddle.Checkout can open the
# correct line item without an extra round-trip.
NEXT_PUBLIC_PADDLE_PRICE_STARTER_MONTH="pri_xxx"
NEXT_PUBLIC_PADDLE_PRICE_STARTER_YEAR="pri_xxx"
NEXT_PUBLIC_PADDLE_PRICE_PRO_MONTH="pri_xxx"
NEXT_PUBLIC_PADDLE_PRICE_PRO_YEAR="pri_xxx"
