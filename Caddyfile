# Production reverse proxy + automatic HTTPS via Let's Encrypt.
# Caddy issues + renews the cert as long as DNS for the domain points
# at this VM. For a fresh-VM test, swap quilpen.com for the bare IP
# (using :80 only) until DNS is cut over.

# Global server timeouts — academic PDF uploads run 5-50 MB and slow
# residential uploads can take 5+ minutes. Default Caddy read_body
# was 30s which aborted big uploads on weak Wi-Fi.
{
	servers {
		timeouts {
			read_body 10m
			read_header 30s
			write 30m
			idle 5m
		}
	}
}

quilpen.com, www.quilpen.com {
	# Caddy automatically sets X-Forwarded-For + X-Forwarded-Proto on
	# every reverse_proxy hop, so middleware sees the real client IP
	# without an explicit header_up directive.
	reverse_proxy web:3000

	# Long uploads — academic PDFs can be 50+ MB. Default Caddy buffer
	# is fine but request_body limit is conservative; bump for safety.
	request_body {
		max_size 100MB
	}
}

# Pre-DNS test: hit the VM's bare IP over HTTP and Caddy serves the
# app + healthz from the catch-all below. Once DNS is cut over, this
# becomes the HTTP→HTTPS redirector.
:80 {
	respond /healthz "ok" 200
	reverse_proxy web:3000
}

